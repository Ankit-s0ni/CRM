{
  "name": "crm-workspace",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev:api": "pnpm --filter api start:dev",
    "dev:web": "pnpm --filter web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter api test:e2e --runInBand",
    "test:web:e2e": "pnpm --filter web test:e2e",
    "load:sprint6:pings": "k6 run tests/load/sprint6/field-pings.js",
    "load:sprint6:sync": "k6 run tests/load/sprint6/attendance-sync.js",
    "load:sprint6:sse": "k6 run tests/load/sprint6/field-sse.js",
    "load:sprint8:punch": "k6 run tests/load/sprint8/punch.js",
    "load:sprint8:sync": "k6 run tests/load/sprint8/sync.js",
    "load:sprint8:pings": "k6 run tests/load/sprint8/pings.js",
    "load:sprint8:reports": "k6 run tests/load/sprint8/reports.js",
    "load:sprint8:live-board": "k6 run tests/load/sprint8/live-board.js",
    "openapi:export": "pnpm --filter api openapi:export",
    "openapi:generate": "pnpm openapi:export && openapi-typescript docs/openapi.json -o packages/contracts/src/generated.ts && node scripts/generate-flutter-api-routes.mjs",
    "security:check": "node scripts/security-check.mjs",
    "release:mobile:check": "node scripts/mobile-release-check.mjs",
    "release:evidence:validate": "node scripts/validate-ga-evidence.mjs --allow-incomplete",
    "release:evidence:check": "node scripts/validate-ga-evidence.mjs",
    "security:sbom": "mkdir -p artifacts/sbom && pnpm sbom --sbom-format cyclonedx --sbom-spec-version 1.6 --sbom-type application --prod --lockfile-only --sbom-supplier DeltCRM > artifacts/sbom/deltcrm.cdx.json && shasum -a 256 artifacts/sbom/deltcrm.cdx.json > artifacts/sbom/deltcrm.cdx.json.sha256",
    "ops:backup": "bash scripts/operations/postgres-backup.sh",
    "ops:restore-drill": "bash scripts/operations/postgres-restore-drill.sh",
    "ops:retention-audit": "bash scripts/operations/retention-audit.sh",
    "ops:partition-audit": "bash scripts/operations/partition-boundary-audit.sh",
    "quality": "pnpm security:check && pnpm release:mobile:check && pnpm release:evidence:validate && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "turbo": "^2.5.6"
  }
}
