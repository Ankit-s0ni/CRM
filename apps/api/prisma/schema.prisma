  PUSH
  EMAIL
  IN_APP
}

enum DeliveryChannel {
  PUSH
  EMAIL
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

enum AlertRuleType {
  ABSENTEE_AFTER_GRACE
  LATE_ARRIVAL
  MISSED_CHECKOUT
  GEOFENCE_VIOLATION
  FACE_MISMATCH
  MOCK_LOCATION
  DEVICE_VIOLATION
  ROOTED_DEVICE
  DEVICE_MISMATCH
  CLOCK_TAMPER
  QUOTA_THRESHOLD
  OFFLINE_SYNC_STALE
}

enum SecurityAlertType {
  GEOFENCE_VIOLATION
  FACE_MISMATCH
  MOCK_LOCATION
  ROOTED_DEVICE
  UNREGISTERED_DEVICE
  DEVICE_MISMATCH
  CLOCK_TAMPER
  ABSENTEE
}

// ---------------- PLATFORM / TENANCY ----------------
model Tenant {
  id                        String       @id @default(uuid(7)) @db.Uuid
  companyName               String
  subdomain                 String       @unique
  status                    TenantStatus @default(TRIAL)
  companyLogo               String?
  suspendedAt               DateTime?
  suspendedReason           String?
  suspendedByPlatformUserId String?      @db.Uuid
  onboardingIdempotencyKey  String?      @unique
  onboardingRequestHash     String?
  onboardingCompletedAt     DateTime?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  settings       TenantSettings?
  billingProfile TenantBillingProfile?
  subscriptions  TenantSubscription[]
  invoices       TenantInvoice[]
  paymentMethods BillingPaymentMethod[]
  deletionJobs   TenantDeletionJob[]
  users          User[]
  employees      Employee[]

  @@index([status, createdAt])
  @@map("tenants")
}

model TenantBillingProfile {
  tenantId     String   @id @db.Uuid
  legalName    String
  billingEmail String
  address      Json?
  gstin        String?
  pan          String?
  currency     String   @default("INR")
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@map("tenant_billing_profiles")
}

model SubscriptionPlan {
  id            String                       @id @default(uuid(7)) @db.Uuid
  name          String                       @unique
  pricePerUser  Decimal                      @db.Decimal(10, 2)
  currency      String                       @default("INR")
  maxEmployees  Int
  billingPeriod BillingPeriod                @default(MONTHLY)
  description   String?
  isActive      Boolean                      @default(true)
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  subscriptions TenantSubscription[]
  modules       SubscriptionPlanModule[]
  capabilities  SubscriptionPlanCapability[]
  history       TenantSubscriptionHistory[]

  @@map("subscription_plans")
}

model SubscriptionPlanModule {
  planId   String           @db.Uuid
  moduleId String           @db.Uuid
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  module   Module           @relation(fields: [moduleId], references: [id])

  @@id([planId, moduleId])
  @@map("subscription_plan_modules")
}

model TenantSubscription {
  id                      String                      @id @default(uuid(7)) @db.Uuid
  tenantId                String                      @db.Uuid
  planId                  String                      @db.Uuid
  status                  SubscriptionStatus          @default(TRIALING)
  seatCount               Int
  currentPeriodStart      DateTime                    @db.Date
  currentPeriodEnd        DateTime                    @db.Date
  dunningState            DunningState                @default(NONE)
  provider                PaymentGateway?
  providerCustomerRef     String?
  providerSubscriptionRef String?
  cancelAtPeriodEnd       Boolean                     @default(false)
  pendingPlanId           String?                     @db.Uuid
  scheduledChangeAt       DateTime?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  tenant                  Tenant                      @relation(fields: [tenantId], references: [id])
  plan                    SubscriptionPlan            @relation(fields: [planId], references: [id])
  invoices                TenantInvoice[]
  history                 TenantSubscriptionHistory[]
  dunningHistory          DunningTransition[]

  @@index([tenantId, status])
  @@map("tenant_subscriptions")
}

model TenantSubscriptionHistory {
  id                  String             @id @default(uuid(7)) @db.Uuid
  tenantId            String             @db.Uuid
  subscriptionId      String             @db.Uuid
  planId              String             @db.Uuid
  status              SubscriptionStatus
  seatCount           Int
  reason              String
  actorUserId         String?            @db.Uuid
  actorPlatformUserId String?            @db.Uuid
  sourceEventId       String?
  snapshot            Json
  createdAt           DateTime           @default(now())
  subscription        TenantSubscription @relation(fields: [subscriptionId], references: [id])
  plan                SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@unique([tenantId, sourceEventId])
  @@index([tenantId, subscriptionId, createdAt])
  @@map("tenant_subscription_history")
}

model Module {
  id                String                   @id @default(uuid(7)) @db.Uuid
  key               String                   @unique
  name              String
  description       String?
  icon              String?
  availability      ModuleAvailability       @default(AVAILABLE)
  kind              ModuleKind               @default(PRODUCT)
  parentModuleId    String?                  @db.Uuid
  catalogOrder      Int                      @default(0)
  customerVisible   Boolean                  @default(true)
  dependencyKeys    String[]                 @default([])
  conflictKeys      String[]                 @default([])
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  tenantModules     TenantModule[]
  subscriptionPlans SubscriptionPlanModule[]
  parentModule      Module?                  @relation("ModuleAddOns", fields: [parentModuleId], references: [id])
  addOns            Module[]                 @relation("ModuleAddOns")
  capabilities      ModuleCapability[]

  @@index([kind, availability, catalogOrder])
  @@index([parentModuleId])
  @@map("modules")
}

model ModuleCapability {
  id                 String                       @id @default(uuid(7)) @db.Uuid
  moduleId           String                       @db.Uuid
  key                String                       @unique
  name               String
  description        String?
  availability       ModuleAvailability           @default(AVAILABLE)
  isCore             Boolean                      @default(false)
  configurable       Boolean                      @default(true)
  requiredModuleKeys String[]                     @default([])
  dependencyKeys     String[]                     @default([])
  conflictKeys       String[]                     @default([])
  displayOrder       Int                          @default(0)
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  module             Module                       @relation(fields: [moduleId], references: [id])
  subscriptionPlans  SubscriptionPlanCapability[]
  tenantOverrides    TenantCapabilityOverride[]

  @@index([moduleId, availability, displayOrder])
  @@map("module_capabilities")
}

model SubscriptionPlanCapability {
  planId       String           @db.Uuid
  capabilityId String           @db.Uuid
  included     Boolean          @default(true)
  limitValue   Json?
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])
  capability   ModuleCapability @relation(fields: [capabilityId], references: [id])

  @@id([planId, capabilityId])
  @@map("subscription_plan_capabilities")
}

model TenantCapabilityOverride {
  id           String             @id @default(uuid(7)) @db.Uuid
  tenantId     String             @db.Uuid
  capabilityId String             @db.Uuid
  mode         TenantOverrideMode
  limitValue   Json?
  reason       String
  startsAt     DateTime?
  endsAt       DateTime?
  changedBy    String             @db.Uuid
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  capability   ModuleCapability   @relation(fields: [capabilityId], references: [id])

  @@unique([tenantId, capabilityId])
  @@index([tenantId, mode])
  @@index([endsAt])
  @@map("tenant_capability_overrides")
}

model TenantModule {
  id          String    @id @default(uuid(7)) @db.Uuid
  tenantId    String    @db.Uuid
  moduleId    String    @db.Uuid
  isActive    Boolean   @default(false)
  activatedAt DateTime?
  activatedBy String?   @db.Uuid
  module      Module    @relation(fields: [moduleId], references: [id])

  @@unique([tenantId, moduleId])
  @@map("tenant_modules")
}

model TenantInvoice {
  id              String                  @id @default(uuid(7)) @db.Uuid
  tenantId        String                  @db.Uuid
  subscriptionId  String                  @db.Uuid
  invoiceNumber   String                  @unique
  fiscalYear      String
  sequenceNumber  Int
  subtotalAmount  Decimal                 @default(0) @db.Decimal(12, 2)
  amountDue       Decimal                 @db.Decimal(12, 2)
  taxAmount       Decimal                 @default(0) @db.Decimal(12, 2)
  cgstAmount      Decimal                 @default(0) @db.Decimal(12, 2)
  sgstAmount      Decimal                 @default(0) @db.Decimal(12, 2)
  igstAmount      Decimal                 @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal                 @db.Decimal(12, 2)
  currency        String                  @default("INR")
  dueDate         DateTime                @db.Date
  status          InvoiceStatus           @default(DRAFT)
  pdfUrl          String?
  objectKey       String?
  pdfChecksum     String?
  billingSnapshot Json
  taxSnapshot     Json
  issuedAt        DateTime?
  paidAt          DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  tenant          Tenant                  @relation(fields: [tenantId], references: [id])
  subscription    TenantSubscription      @relation(fields: [subscriptionId], references: [id])
  transactions    PaymentTransaction[]
  lineItems       TenantInvoiceLineItem[]

  @@unique([fiscalYear, sequenceNumber])
  @@index([tenantId, status])
  @@map("tenant_invoices")
}

model TenantInvoiceLineItem {
  id          String        @id @default(uuid(7)) @db.Uuid
  tenantId    String        @db.Uuid
  invoiceId   String        @db.Uuid
  description String
  quantity    Decimal       @db.Decimal(12, 3)
  unitAmount  Decimal       @db.Decimal(12, 2)
  amount      Decimal       @db.Decimal(12, 2)
  taxRate     Decimal       @default(0) @db.Decimal(5, 2)
  metadata    Json?
  invoice     TenantInvoice @relation(fields: [invoiceId], references: [id])

  @@index([tenantId, invoiceId])
  @@map("tenant_invoice_line_items")
}

model InvoiceSequence {
  fiscalYear String   @id
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@map("invoice_sequences")
}

model PaymentTransaction {
  id              String         @id @default(uuid(7)) @db.Uuid
  tenantId        String         @db.Uuid
  invoiceId       String         @db.Uuid
  gateway         PaymentGateway
  gatewayRef      String?
  amount          Decimal        @db.Decimal(12, 2)
  currency        String         @default("INR")
  status          PaymentStatus  @default(PENDING)
  failureReason   String?
  providerEventId String?
  idempotencyKey  String?
  metadata        Json?
  attemptedAt     DateTime       @default(now())
  invoice         TenantInvoice  @relation(fields: [invoiceId], references: [id])

  @@unique([gateway, gatewayRef])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, invoiceId, attemptedAt])
  @@map("payment_transactions")
}

model BillingPaymentMethod {
  id                String              @id @default(uuid(7)) @db.Uuid
  tenantId          String              @db.Uuid
  gateway           PaymentGateway
  providerMethodRef String
  methodType        PaymentMethodType
  displayName       String
  lastFour          String?
  expiryMonth       Int?
  expiryYear        Int?
  isDefault         Boolean             @default(false)
  status            PaymentMethodStatus @default(ACTIVE)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  tenant            Tenant              @relation(fields: [tenantId], references: [id])

  @@unique([gateway, providerMethodRef])
  @@index([tenantId, status])
  @@map("billing_payment_methods")
}

model BillingWebhookReceipt {
  id              String               @id @default(uuid(7)) @db.Uuid
  provider        PaymentGateway
  providerEventId String
  eventType       String
  occurredAt      DateTime
  payloadHash     String
  status          WebhookReceiptStatus @default(RECEIVED)
  attemptCount    Int                  @default(0)
  normalizedEvent Json?
  outcome         Json?
  failureCode     String?
  processedAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([provider, providerEventId])
  @@index([status, createdAt])
  @@map("billing_webhook_receipts")
}

model DunningTransition {
  id             String             @id @default(uuid(7)) @db.Uuid
  tenantId       String             @db.Uuid
  subscriptionId String             @db.Uuid
  action         DunningAction
  fromState      DunningState
  toState        DunningState
  idempotencyKey String
  reason         String
  scheduledFor   DateTime?
  completedAt    DateTime?
  metadata       Json?
  createdAt      DateTime           @default(now())
  subscription   TenantSubscription @relation(fields: [subscriptionId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, subscriptionId, createdAt])
  @@index([scheduledFor, completedAt])
  @@map("dunning_transitions")
}

model TenantDeletionJob {
  id                String            @id @default(uuid(7)) @db.Uuid
  tenantId          String            @db.Uuid
  status            DeletionJobStatus @default(PENDING)
  requestedBy       String?           @db.Uuid
  reason            String
  legalHoldUntil    DateTime?
  biometricPurgedAt DateTime?
  completedAt       DateTime?
  failureCode       String?
  evidence          Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  tenant            Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@map("tenant_deletion_jobs")
}

model PlatformUser {
  id                String                    @id @default(uuid(7)) @db.Uuid
  email             String                    @unique
  passwordHash      String
  role              PlatformRole
  mfaSecret         String?
  mfaEnabled        Boolean                   @default(false)
  failedLoginCount  Int                       @default(0)
  lockedUntil       DateTime?
  passwordChangedAt DateTime?
  lastLoginAt       DateTime?
  lastLoginIp       String?
  status            UserStatus                @default(ACTIVE)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  impersonations    ImpersonationSession[]
  authChallenges    PlatformAuthChallenge[]
  sessions          PlatformSession[]
  recoveryCodes     PlatformMfaRecoveryCode[]

  @@map("platform_users")
}

model PlatformAuthChallenge {
  id             String       @id @default(uuid(7)) @db.Uuid
  platformUserId String       @db.Uuid
  tokenHash      String       @unique
  attemptCount   Int          @default(0)
  expiresAt      DateTime
  consumedAt     DateTime?
  createdIp      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  platformUser   PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId, expiresAt])
  @@map("platform_auth_challenges")
}

model PlatformSession {
  id             String                 @id @default(uuid(7)) @db.Uuid
  platformUserId String                 @db.Uuid
  mfaVerifiedAt  DateTime
  expiresAt      DateTime
  revokedAt      DateTime?
  createdIp      String?
  userAgent      String?
  createdAt      DateTime               @default(now())
  lastSeenAt     DateTime               @default(now())
  platformUser   PlatformUser           @relation(fields: [platformUserId], references: [id], onDelete: Cascade)
  refreshTokens  PlatformRefreshToken[]
  impersonations ImpersonationSession[]

  @@index([platformUserId, revokedAt, expiresAt])
  @@map("platform_sessions")
}

model PlatformRefreshToken {
  id            String          @id @default(uuid(7)) @db.Uuid
  sessionId     String          @db.Uuid
  tokenHash     String          @unique
  familyId      String          @db.Uuid
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason RevokeReason?
  createdIp     String?
  userAgent     String?
  createdAt     DateTime        @default(now())
  session       PlatformSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, familyId, revokedAt])
  @@map("platform_refresh_tokens")
}

model PlatformMfaRecoveryCode {
  id             String       @id @default(uuid(7)) @db.Uuid
  platformUserId String       @db.Uuid
  codeHash       String       @unique
  usedAt         DateTime?
  createdAt      DateTime     @default(now())
  platformUser   PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId, usedAt])
  @@map("platform_mfa_recovery_codes")
}

model PlatformPermission {
  id              String                   @id @default(uuid(7)) @db.Uuid
  key             String                   @unique
  rolePermissions PlatformRolePermission[]

  @@map("platform_permissions")
}

model PlatformRolePermission {
  role         PlatformRole
  permissionId String             @db.Uuid
  permission   PlatformPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([role, permissionId])
  @@map("platform_role_permissions")
}

model ImpersonationSession {
  id                    String          @id @default(uuid(7)) @db.Uuid
  platformUserId        String          @db.Uuid
  platformSessionId     String          @db.Uuid
  tenantId              String          @db.Uuid
  targetUserId          String          @db.Uuid
  tokenJti              String          @unique @db.Uuid
  scopes                String[]        @default([])
  reason                String
  startedAt             DateTime        @default(now())
  endedAt               DateTime?
  endedReason           String?
  endedByPlatformUserId String?         @db.Uuid
  expiresAt             DateTime
  ipAddress             String?
  userAgent             String?
  platformUser          PlatformUser    @relation(fields: [platformUserId], references: [id])
  platformSession       PlatformSession @relation(fields: [platformSessionId], references: [id], onDelete: Cascade)

  @@index([tenantId, startedAt])
  @@index([platformUserId, endedAt, expiresAt])
  @@index([targetUserId, endedAt, expiresAt])
  @@map("impersonation_sessions")
}

model SystemAlert {
  id               String          @id @default(uuid(7)) @db.Uuid
  alertType        SystemAlertType
  severity         AlertSeverity
  title            String
  payload          Json?
  tenantId         String?         @db.Uuid
  status           AlertStatus     @default(OPEN)
  acknowledgedBy   String?         @db.Uuid
  acknowledgedAt   DateTime?
  acknowledgedNote String?
  resolvedBy       String?         @db.Uuid
  resolvedAt       DateTime?
  resolvedNote     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status, severity, createdAt])
  @@map("system_alerts")
}

model SystemAuditLog {
  id                     String   @id @default(uuid(7)) @db.Uuid
  actorPlatformUserId    String?  @db.Uuid
  impersonationSessionId String?  @db.Uuid
  tenantId               String?  @db.Uuid
  action                 String
  module                 String
  oldValue               Json?
  newValue               Json?
  ipAddress              String?
  userAgent              String?
  requestId              String?
  createdAt              DateTime @default(now())

  @@index([actorPlatformUserId, createdAt])
  @@index([tenantId, createdAt])
  @@index([module, createdAt])
  @@index([action, createdAt])
  @@map("system_audit_logs")
}

// ---------------- IDENTITY & ACCESS ----------------
model User {
  id                      String                   @id @default(uuid(7)) @db.Uuid
  tenantId                String                   @db.Uuid
  email                   String
  phone                   String?
  passwordHash            String
  status                  UserStatus               @default(ACTIVE)
  emailVerifiedAt         DateTime?
  passwordChangedAt       DateTime?
