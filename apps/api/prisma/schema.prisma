// =====================================================================
// schema.prisma — v4 (matches erd-v4.puml)
// Conventions: uuidv7 PKs; tenantId + createdAt + updatedAt on all
// tenant-scoped models; every tenant index leads with tenantId.
// Partitioned tables (AttendanceEvent, AttendanceVerificationLog,
// FieldLocationPing, TenantAuditLog) — DDL owned by rls-and-partitions.sql.
// Platform tables (Tenant, plans, invoices, PlatformUser...) are accessed
// via the app_admin connection by the platform module only.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------- ENUMS ----------------
enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CHURNED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum DunningState {
  NONE
  REMINDED
  GRACE
  SUSPEND_PENDING
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentGateway {
  STRIPE
  RAZORPAY
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum WebhookReceiptStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}

enum PaymentMethodStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum PaymentMethodType {
  CARD
  BANK_ACCOUNT
  UPI
  WALLET
}

enum DunningAction {
  PAYMENT_FAILED
  REMINDER_SENT
  GRACE_STARTED
  SUSPEND_SCHEDULED
  TENANT_SUSPENDED
  PAYMENT_RECOVERED
  TENANT_REACTIVATED
}

enum DeletionJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  LEGAL_HOLD
}

enum BillingPeriod {
  MONTHLY
  YEARLY
}

enum PlatformRole {
  SUPER_ADMIN
  SUPPORT
}

enum ModuleAvailability {
  AVAILABLE
  COMING_SOON
  DEPRECATED
}

enum ModuleKind {
  PRODUCT
  ADD_ON
}

enum TenantOverrideMode {
  INHERIT
  ENABLE
  DISABLE
}

enum SystemAlertType {
  PAYMENT_GATEWAY_DOWN
  QUEUE_LAG
  PUSH_FAILURE
  NEW_SUBSCRIPTION
  PLAN_UPGRADED
  TENANT_SUSPENDED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum UserStatus {
  ACTIVE
  LOCKED
  DISABLED
}

enum TokenPurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
  USER_INVITE
  TENANT_SIGNUP
}

enum RevokeReason {
  LOGOUT
  ROTATED
  REUSE_DETECTED
  ADMIN
  PASSWORD_CHANGE
}

enum LoginFailReason {
  BAD_PASSWORD
  LOCKED
  DISABLED
  UNKNOWN_USER
  MFA_FAILED
}

enum WorkType {
  OFFICE
  FIELD
  HYBRID
}

enum EmployeeStatus {
  ACTIVE
  ON_NOTICE
  TERMINATED
}

enum EmploymentEventType {
  JOINED
  TRANSFERRED
  PROMOTED
  EXITED
}

enum ImportKind {
  EMPLOYEES
  ROSTERS
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ImportRowStatus {
  PENDING
  VALIDATED
  IMPORTED
  ERROR
}

enum DevicePlatform {
  IOS
  ANDROID
}

enum DeviceStatus {
  PENDING_APPROVAL
  ACTIVE
  BLOCKED
  REPLACED
}

enum FaceEnrollmentStatus {
  ACTIVE
  REPLACED
  REVOKED
}

enum BiometricConsentAction {
  GRANTED
  WITHDRAWN
}

enum AttendanceStatus {
  PRESENT_OPEN
  PRESENT
  HALF_DAY
  ABSENT
  ON_LEAVE
  HOLIDAY
  WEEKLY_OFF
  ON_DUTY
}

enum EventType {
  CHECKIN
  CHECKOUT
  BREAK_START
  BREAK_END
  REGULARIZED_CHECKIN
  REGULARIZED_CHECKOUT
}

enum PunchSource {
  MOBILE
  WEB
  KIOSK
  REGULARIZED
}

enum VerificationType {
  CHECKIN
  CHECKOUT
}

enum VerificationStatus {
  PASSED
  FAILED
}

enum LocationMethod {
  GEOFENCE
  OFFICE_IP
  GPS_ONLY
  NONE
}

enum AttendanceLocationMode {
  NONE
  OFFICE_GEOFENCE
  FIELD_GPS
}

enum SelfieMode {
  DISABLED
  REQUIRED
}

enum ExceptionType {
  ON_DUTY
  LEAVE
  WFH
  OTHER
}

enum ExceptionSource {
  MANUAL
  LEAVE_MODULE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PolicyScope {
  TENANT_DEFAULT
  DEPARTMENT
  EMPLOYEE
}

enum TrackingEndReason {
  CHECKOUT
  MANUAL
  BATTERY
  STALE
  ADMINISTRATOR
}

enum FieldIngestionStatus {
  PENDING
  PROCESSED
  REJECTED
}

enum AttendanceSyncStatus {
  ACCEPTED
  RETRYABLE
  REJECTED
}

enum LockStatus {
  OPEN
  LOCKED
  REOPENED
}

enum ReportType {
  MUSTER
  PAYROLL
  LATE_OT
  VIOLATIONS
  FIELD_DISTANCE
}

enum ReportFormat {
  CSV
  XLSX
  PDF
}

enum PayrollLockAction {
  LOCKED
  REOPENED
