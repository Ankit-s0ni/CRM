  gaps               Json      @default("[]")
  sourceStartedAt    DateTime?
  sourceEndedAt      DateTime?
  algorithmVersion   Int       @default(1)
  updatedAt          DateTime  @updatedAt

  @@unique([tenantId, employeeId, routeDate])
  @@map("field_route_summaries")
}

model AttendanceSyncReceipt {
  id                      String               @id @default(uuid(7)) @db.Uuid
  tenantId                String               @db.Uuid
  employeeId              String               @db.Uuid
  clientEventUuid         String               @db.Uuid
  payloadHash             String
  status                  AttendanceSyncStatus
  attendanceEventId       String?              @db.Uuid
  errorCode               String?
  message                 String?
  regularizationSuggested Boolean              @default(false)
  clientTime              DateTime
  outcome                 Json
  processedAt             DateTime             @default(now())
  createdAt               DateTime             @default(now())

  @@unique([tenantId, clientEventUuid])
  @@index([tenantId, employeeId, processedAt])
  @@map("attendance_sync_receipts")
}

model DeviceIntegrityChallenge {
  id         String    @id @default(uuid(7)) @db.Uuid
  tenantId   String    @db.Uuid
  employeeId String    @db.Uuid
  deviceId   String    @db.Uuid
  nonceHash  String
  action     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId, deviceId, expiresAt])
  @@index([tenantId, consumedAt, expiresAt])
  @@map("device_integrity_challenges")
}

model RegularizationRequest {
  id                String            @id @default(uuid(7)) @db.Uuid
  tenantId          String            @db.Uuid
  attendanceLogId   String            @db.Uuid
  employeeId        String            @db.Uuid
  requestedCheckin  DateTime?
  requestedCheckout DateTime?
  reason            String
  attachmentKey     String?
  managerComments   String?
  status            RequestStatus     @default(PENDING)
  approvedBy        String?           @db.Uuid
  approvedAt        DateTime?
  cancelledAt       DateTime?
  idempotencyKey    String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  attendanceLog     AttendanceLog     @relation(fields: [attendanceLogId], references: [id])
  employee          Employee          @relation(fields: [employeeId], references: [id])
  syntheticEvents   AttendanceEvent[]

  @@unique([tenantId, employeeId, attendanceLogId])
  @@unique([tenantId, employeeId, idempotencyKey])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, employeeId])
  @@map("regularization_requests")
}

model BiometricConsent {
  id               String                 @id @default(uuid(7)) @db.Uuid
  tenantId         String                 @db.Uuid
  employeeId       String                 @db.Uuid
  action           BiometricConsentAction @default(GRANTED)
  policyVersion    String
  consentedAt      DateTime               @default(now())
  revokedAt        DateTime?
  consentIp        String?
  consentUserAgent String?
  employee         Employee               @relation(fields: [employeeId], references: [id])

  @@index([tenantId, employeeId, consentedAt])
  @@map("biometric_consents")
}

model FaceEnrollment {
  id               String               @id @default(uuid(7)) @db.Uuid
  tenantId         String               @db.Uuid
  employeeId       String               @db.Uuid
  version          Int
  privateObjectKey String
  embeddingRef     String
  livenessProvider String
  status           FaceEnrollmentStatus @default(ACTIVE)
  enrolledAt       DateTime             @default(now())
  enrolledBy       String               @db.Uuid
  revokedAt        DateTime?
  employee         Employee             @relation(fields: [employeeId], references: [id])

  @@unique([tenantId, employeeId, version])
  @@index([tenantId, employeeId, status])
  @@map("face_enrollments")
}

/// Append-only; PARTITIONED monthly on createdAt.
model TenantAuditLog {
  id                     String   @id @default(uuid(7)) @db.Uuid
  tenantId               String   @db.Uuid
  actorUserId            String?  @db.Uuid
  impersonationSessionId String?  @db.Uuid
  action                 String
  module                 String
  entityType             String?
  entityId               String?  @db.Uuid
  oldValue               Json?
  newValue               Json?
  ipAddress              String?
  userAgent              String?
  requestId              String?
  createdAt              DateTime @default(now())

  @@index([tenantId, module, createdAt])
  @@index([tenantId, entityType, entityId])
  @@map("tenant_audit_logs")
}

model ReportExport {
  id              String              @id @default(uuid(7)) @db.Uuid
  tenantId        String              @db.Uuid
  requestedBy     String              @db.Uuid
  reportType      ReportType
  period          String
  format          ReportFormat        @default(CSV)
  contractVersion Int                 @default(1)
  filters         Json                @default("{}")
  sourceCutoff    DateTime
  sourceWatermark String?
  status          JobStatus           @default(PENDING)
  objectKey       String?
  checksum        String?
  failureCode     String?
  failureMessage  String?
  fileUrl         String?
  expiresAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  requester       User                @relation(fields: [requestedBy], references: [id])
  payrollLocks    PayrollLockPeriod[]

  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
  @@map("report_exports")
}

// ---------------- LEAVE ----------------
model LeavePolicy {
  id           String         @id @default(uuid(7)) @db.Uuid
  tenantId     String         @db.Uuid
  name         String
  leaveType    String
  accrualLogic Json           @default("{}")
  version      Int            @default(1)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  balances     LeaveBalance[]
  requests     LeaveRequest[]

  @@unique([tenantId, name])
  @@map("leave_policies")
}

model LeaveBalance {
  id            String               @id @default(uuid(7)) @db.Uuid
  tenantId      String               @db.Uuid
  employeeId    String               @db.Uuid
  policyId      String               @db.Uuid
  remainingDays Decimal              @db.Decimal(5, 2)
  policy        LeavePolicy          @relation(fields: [policyId], references: [id])
  employee      Employee             @relation(fields: [employeeId], references: [id])
  ledger        LeaveBalanceLedger[]
  updatedAt     DateTime             @updatedAt

  @@unique([tenantId, employeeId, policyId])
  @@map("leave_balances")
}

model LeaveBalanceLedger {
  id             String                @id @default(uuid(7)) @db.Uuid
  tenantId       String                @db.Uuid
  balanceId      String                @db.Uuid
  leaveRequestId String?               @db.Uuid
  entryType      LeaveBalanceEntryType
  days           Decimal               @db.Decimal(5, 2)
  balanceAfter   Decimal               @db.Decimal(5, 2)
  reason         String
  actorUserId    String?               @db.Uuid
  idempotencyKey String
  createdAt      DateTime              @default(now())
  balance        LeaveBalance          @relation(fields: [balanceId], references: [id])
  leaveRequest   LeaveRequest?         @relation(fields: [leaveRequestId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, balanceId, createdAt])
  @@map("leave_balance_ledger")
}

model LeaveRequest {
  id                  String               @id @default(uuid(7)) @db.Uuid
  tenantId            String               @db.Uuid
  employeeId          String               @db.Uuid
  policyId            String               @db.Uuid
  startDate           DateTime             @db.Date
  endDate             DateTime             @db.Date
  halfDayStart        Boolean              @default(false)
  halfDayEnd          Boolean              @default(false)
  totalDays           Decimal              @db.Decimal(5, 2)
  reason              String?
  status              RequestStatus        @default(PENDING)
  approvedBy          String?              @db.Uuid
  approvedAt          DateTime?
  managerComments     String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  policy              LeavePolicy          @relation(fields: [policyId], references: [id])
  employee            Employee             @relation(fields: [employeeId], references: [id])
  balanceEntries      LeaveBalanceLedger[]
  attendanceException AttendanceException?

  @@index([tenantId, status, createdAt])
  @@index([tenantId, employeeId, startDate, endDate])
  @@map("leave_requests")
}

// ---------------- NOTIFICATIONS & ALERTS ----------------
model NotificationTemplate {
  id                String       @id @default(uuid(7)) @db.Uuid
  eventKey          String
  channel           NotifChannel
  locale            String       @default("en")
  subject           String?
  bodyTemplate      String
  requiredVariables Json         @default("[]")
  version           Int          @default(1)
  isActive          Boolean      @default(true)

  @@unique([eventKey, channel, locale])
  @@map("notification_templates")
}

model AlertRule {
  id              String          @id @default(uuid(7)) @db.Uuid
  tenantId        String          @db.Uuid
  ruleType        AlertRuleType
  isActive        Boolean         @default(true)
  thresholdConfig Json            @default("{}")
  channels        Json            @default("[\"IN_APP\"]")
  notifyRoles     Json            @default("[]")
  notifyUserIds   Json            @default("[]")
  scopeDeptIds    Json            @default("[]")
  cooldownMinutes Int             @default(60)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  alerts          SecurityAlert[]

  @@unique([tenantId, ruleType])
  @@map("alert_rules")
}

model SecurityAlert {
  id                String            @id @default(uuid(7)) @db.Uuid
  tenantId          String            @db.Uuid
  employeeId        String            @db.Uuid
  verificationLogId String?           @db.Uuid
  attendanceEventId String?           @db.Uuid
  ruleId            String?           @db.Uuid
  alertType         SecurityAlertType
  severity          AlertSeverity     @default(WARNING)
  title             String
  details           Json              @default("{}")
  status            AlertStatus       @default(OPEN)
  acknowledgedBy    String?           @db.Uuid
  acknowledgedAt    DateTime?
  resolvedBy        String?           @db.Uuid
  resolvedAt        DateTime?
  resolutionNote    String?
  createdAt         DateTime          @default(now())
  rule              AlertRule?        @relation(fields: [ruleId], references: [id])

  @@index([tenantId, status, createdAt])
  @@index([tenantId, employeeId, createdAt])
  @@index([tenantId, verificationLogId])
  @@map("security_alerts")
}

model NotificationPreference {
  id       String       @id @default(uuid(7)) @db.Uuid
  tenantId String       @db.Uuid
  userId   String       @db.Uuid
  eventKey String
  channel  NotifChannel
  enabled  Boolean      @default(true)
  user     User         @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId, eventKey, channel])
  @@map("notification_preferences")
}

model Notification {
  id            String                 @id @default(uuid(7)) @db.Uuid
  tenantId      String                 @db.Uuid
  userId        String                 @db.Uuid
  eventKey      String
  dedupeKey     String
  severity      AlertSeverity          @default(INFO)
  title         String
  body          String
  module        String?
  referenceType String?
  referenceId   String?                @db.Uuid
  actionUrl     String?
  data          Json?
  isRead        Boolean                @default(false)
  readAt        DateTime?
  expiresAt     DateTime?
  createdAt     DateTime               @default(now())
  deliveries    NotificationDelivery[]
  user          User                   @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId, dedupeKey])
  @@index([tenantId, userId, isRead, createdAt])
  @@map("notifications")
}

model NotificationDelivery {
  id             String          @id @default(uuid(7)) @db.Uuid
  notificationId String          @db.Uuid
  channel        DeliveryChannel
  status         DeliveryStatus  @default(PENDING)
  attemptNumber  Int             @default(1)
  providerRef    String?
  providerCode   String?
  errorMessage   String?
  retryCount     Int             @default(0)
  deviceId       String?         @db.Uuid
  nextAttemptAt  DateTime?
  attemptedAt    DateTime        @default(now())
  deliveredAt    DateTime?
  notification   Notification    @relation(fields: [notificationId], references: [id])

  @@index([notificationId])
  @@map("notification_deliveries")
}

// ---------------- INFRASTRUCTURE ----------------
model OutboxEvent {
  id             String    @id @default(uuid(7)) @db.Uuid
  tenantId       String?   @db.Uuid
  eventKey       String
  payload        Json
  createdAt      DateTime  @default(now())
  availableAt    DateTime  @default(now())
  publishedAt    DateTime?
  lockedAt       DateTime?
  lockedBy       String?
  attemptCount   Int       @default(0)
  lastError      String?
  deadLetteredAt DateTime?

  @@index([publishedAt, deadLetteredAt, availableAt, createdAt], map: "outbox_events_delivery_idx")
  @@map("outbox_events")
}
