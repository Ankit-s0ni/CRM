DATABASE_URL=postgresql://app_admin:admin_password@localhost:5433/hrms_dev?schema=public
DATABASE_URL_APP=postgresql://app_user:app_password@localhost:5433/hrms_dev?schema=public
DATABASE_URL_PLATFORM=postgresql://platform_runtime:platform_password@localhost:5433/hrms_dev?schema=public
DEVICE_INTEGRITY_PROVIDER_URL=https://integrity-provider.example.com/verify
DEVICE_INTEGRITY_PROVIDER_TOKEN=replace-with-secret-manager-value
# Set only after the production integrity gateway has passed the Sprint 6 certification matrix.
DEVICE_INTEGRITY_ENFORCEMENT_ENABLED=false
FACE_MATCH_PROVIDER_URL=https://face-provider.example.com/compare
FACE_MATCH_PROVIDER_TOKEN=replace-with-secret-manager-value
# Required only after an approved server-side liveness provider is selected.
FACE_LIVENESS_PROVIDER_URL=https://face-provider.example.com/enroll
FACE_LIVENESS_PROVIDER_TOKEN=replace-with-secret-manager-value
# Keep false until the provider, privacy and physical-device certification matrix is complete.
BIOMETRICS_ENFORCEMENT_ENABLED=false
# Comma-separated IP/CIDR ranges for known reverse proxies only. Leave unset for direct traffic.
TRUSTED_PROXIES=loopback
INTEGRITY_CHALLENGE_RETENTION_DAYS=7
INTEGRITY_CHALLENGE_CLEANUP_INTERVAL_MS=3600000
TOKEN_RETENTION_DAYS=7
RETENTION_BATCH_SIZE=1000
RETENTION_INTERVAL_MS=3600000
EVIDENCE_DELETION_MAX_ATTEMPTS=12
REDIS_URL=redis://localhost:6379
REPORT_QUEUE_MODE=worker
REPORT_WORKER_CONCURRENCY=2
LEAVE_EVENT_WORKER_CONCURRENCY=2
LEAVE_EVENT_MAX_ATTEMPTS=10
S3_PRIVATE_BUCKET=hrms-private
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
IMPORT_QUEUE_MODE=worker
IMPORT_WORKER_CONCURRENCY=2
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PRIVATE_BUCKET=hrms-private
S3_BUCKET=hrms-uploads
JWT_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
# Production releases must provide real store links and semantic versions.
MOBILE_MINIMUM_VERSION=1.0.0
MOBILE_RECOMMENDED_VERSION=1.0.0
MOBILE_ANDROID_UPDATE_URL=https://play.google.com/store/apps/details?id=com.deltcrm.employee
MOBILE_IOS_UPDATE_URL=https://apps.apple.com/app/deltcrm/id000000000
# Error reporting and tracing remain disabled outside production.
SENTRY_DSN=https://public@example.ingest.sentry.io/1
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com/v1/traces
OTEL_SERVICE_NAME=deltcrm-api
RELEASE_VERSION=1.0.0
DEPLOYMENT_ENVIRONMENT=production
OBSERVABILITY_ALERT_WEBHOOK_URL=https://alerts.example.com/hooks/deltcrm
PLATFORM_MFA_REQUIRED=false
TENANT_ADMIN_PASSWORD=TenantAdmin123!
MOBILE_EMPLOYEE_PASSWORD=Employee123!
# Notification gateway adapters use HTTP ports so attendance code never calls
# FCM or email vendors directly. Leave blank only for local development.
FCM_GATEWAY_URL=https://notifications.example.com/fcm/send
FCM_GATEWAY_TOKEN=replace-me
EMAIL_GATEWAY_URL=https://notifications.example.com/email/send
EMAIL_GATEWAY_TOKEN=replace-me
